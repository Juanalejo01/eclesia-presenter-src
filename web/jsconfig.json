{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "allowJs": true,
    "checkJs": false
  },
  "include": ["app/**/*", "components/**/*", "lib/**/*"],
  "exclude": ["node_modules", ".next"]
}
