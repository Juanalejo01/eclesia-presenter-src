# ============================================================
# EclesiaPresenter Web — variables de entorno
# Copia este archivo a .env.local y rellena con tus valores reales
# En Vercel: Project Settings → Environment Variables (las mismas)
# ============================================================

# URL pública del sitio (sin / al final)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- SUPABASE ---
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGc..."
# CRÍTICO: service role — NUNCA exponer en cliente
SUPABASE_SERVICE_ROLE="eyJhbGc..."

# --- STRIPE (próxima sesión v0.3) ---
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Price IDs de cada plan (los creas en Stripe Products)
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME="price_..."

# --- RESEND (email transaccional, próxima sesión) ---
RESEND_API_KEY="re_..."
