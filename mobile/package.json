{
  "name": "@eclesia-presenter/mobile",
  "private": true,
  "version": "0.1.0",
  "description": "EclesiaPresenter mobile remote — Android/iOS/PWA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "cap open android",
    "cap:run:android": "cap run android"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/__tests__/**/*.test.js"],
    "transform": {
      "^.+\\.jsx?$": ["babel-jest", { "presets": ["@babel/preset-env"] }]
    },
    "moduleNameMapper": {
      "^@capacitor/preferences$": "<rootDir>/__tests__/__mocks__/capacitor-preferences.js"
    }
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/haptics": "^6.0.1",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@capacitor/cli": "^6.1.2",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2"
  }
}
