{
  "name": "@eclesia-presenter/mobile",
  "private": true,
  "version": "0.2.0",
  "description": "EclesiaPresenter mobile remote — Android/iOS/PWA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:app": "vite build --base=/app/ --outDir dist-app",
    "preview": "vite preview",
    "test": "jest",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "cap open android",
    "cap:run:android": "cap run android"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/__tests__/**/*.test.js",
      "<rootDir>/__tests__/**/*.test.jsx"
    ],
    "projects": [
      {
        "displayName": "node",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/__tests__/**/*.test.js"
        ],
        "transform": {
          "^.+\\.jsx?$": [
            "babel-jest",
            {
              "presets": [
                "@babel/preset-env"
              ]
            }
          ]
        },
        "moduleNameMapper": {
          "^@capacitor/preferences$": "<rootDir>/__tests__/__mocks__/capacitor-preferences.js",
          "^@capacitor/core$": "<rootDir>/__tests__/__mocks__/capacitor-core.js"
        }
      },
      {
        "displayName": "jsdom",
        "testEnvironment": "jsdom",
        "testMatch": [
          "<rootDir>/__tests__/**/*.test.jsx"
        ],
        "transform": {
          "^.+\\.jsx?$": [
            "babel-jest",
            {
              "presets": [
                "@babel/preset-env",
                [
                  "@babel/preset-react",
                  {
                    "runtime": "automatic"
                  }
                ]
              ]
            }
          ]
        },
        "moduleNameMapper": {
          "^@capacitor/preferences$": "<rootDir>/__tests__/__mocks__/capacitor-preferences.js",
          "^@capacitor/core$": "<rootDir>/__tests__/__mocks__/capacitor-core.js"
        }
      }
    ]
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/haptics": "^6.0.1",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@hello-pangea/dnd": "^17.0.0",
    "jsqr": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@capacitor/cli": "^6.1.2",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^0.20.5"
  }
}
