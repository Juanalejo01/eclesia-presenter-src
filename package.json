{
  "name": "eclesia-presenter",
  "version": "0.2.0",
  "description": "Software de presentación para iglesias — Biblia, canciones, lista, proyección OBS",
  "main": "src/main/main.js",
  "homepage": "https://github.com/Juanalejo01/eclesia-presenter",
  "author": "Juanalejo01",
  "license": "MIT",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win portable",
    "dist:installer": "npm run build && electron-builder --win nsis",
    "dist:all": "npm run build && electron-builder --win portable nsis && node build/embed-icon.js",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "icon": "node build/generate-icons.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@sentry/electron": "^5.10.0",
    "better-sqlite3": "^11.10.0",
    "express": "^4.18.3",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.eclesiapresenter.app",
    "productName": "EclesiaPresenter",
    "copyright": "Copyright © 2026 Juanalejo01",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "src/main/**/*",
      "src/server/**/*",
      "dist/renderer/**/*",
      "package.json",
      "!**/*.map"
    ],
    "extraResources": [
      { "from": "build/icon.ico", "to": "icon.ico" },
      { "from": "build/icon.png", "to": "icon.png" }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EclesiaPresenter",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "zip",
          "arch": ["arm64"]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "AudioVideo",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": null
  }
}
