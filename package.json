{
  "name": "eclesia-presenter",
  "version": "0.1.0",
  "description": "Software de presentación para iglesias — letras, Biblia, OBS overlay, control móvil",
  "main": "src/main/main.js",
  "homepage": "https://github.com/tu-usuario/eclesia-presenter",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
