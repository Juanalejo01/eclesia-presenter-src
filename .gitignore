# Dependencies
node_modules/

# Build output
dist/
dist-electron/
out/

# Recursos de build (icons, etc.) NO se ignoran — son source files.
# electron-builder los usa como input desde build/icon.ico, build/icon.png, etc.
# Las imágenes PNG numeradas intermedias (icon-16.png, icon-32.png, …) SÍ se
# ignoran porque son outputs regenerables del script npm run icon.
# Pero icon.ico y icon.png deben estar versionados para que el workflow de
# release.yml los encuentre (no corremos npm run icon en CI).
build/icon-*.png

# Next.js (web/) — siempre se ignora
web/.next/
web/out/
web/.vercel

# Environment / secrets
.env
.env.local
.env.*.local

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Claude Code local config
.claude/settings.local.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Reference design files (kept locally, not part of the app)
design-reference/

# Electron user data (if generated locally)
*.sqlite
*.db
