# Dependencies
node_modules/

# Build output
dist/
dist-electron/
out/

# Recursos de build (icons, etc.) NO se ignoran — son source files.
# electron-builder los usa como input desde build/icon.ico, build/icon.png, etc.
# Las imágenes PNG generadas a partir del SVG sí se ignoran para no inflar el repo.
build/icon-*.png
build/icon.png
build/icon.ico

# Next.js (web/) — siempre se ignora
web/.next/
web/out/
web/.vercel

# Environment / secrets
.env
.env.local
.env.*.local

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Claude Code local config
.claude/settings.local.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Reference design files (kept locally, not part of the app)
design-reference/

# Electron user data (if generated locally)
*.sqlite
*.db
